rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Profiles ---
    match /users/{userId} {
      // Allow getting and listing profiles for discovery
      allow read: if isSignedIn();
      
      // Prevent privilege escalation: Users cannot modify their own protected fields
      allow write: if isAdmin() || (
        isOwner(userId) && (
          (resource == null && !request.resource.data.keys().hasAny(['role', 'isAdmin', 'isBanned', 'isPremium', 'tier', 'isManaged'])) ||
          (resource != null && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin', 'isBanned', 'isPremium', 'tier', 'isManaged']))
        )
      );
    }

    // --- Connections & Requests ---
    match /requests/{requestId} {
      // Users can see requests they sent or received
      allow read: if isSignedIn() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId || isAdmin());
      
      // Users can only create requests as themselves
      allow create: if isSignedIn() && (request.auth.uid == request.resource.data.fromId || isAdmin());
      
      // Security Fix: Only the RECIPIENT can accept/decline a request
      // The sender can only cancel (delete) a pending request
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.toId) || 
        (request.auth.uid == resource.data.fromId && request.resource.data.status == 'declined') ||
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.fromId || isAdmin());
    }

    // --- Matches (Connections) ---
    match /matches/{matchId} {
      // Only participants or admins can read match data
      allow read: if isSignedIn() && (request.auth.uid in resource.data.users || isAdmin());
      
      // Matches should only be created when a request is accepted.
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.users || isAdmin());
      
      // Only participants can update (e.g. lastMessage)
      allow update: if isSignedIn() && (request.auth.uid in resource.data.users || isAdmin());
    }

    // --- Chat Messages ---
    match /matches/{matchId}/messages/{messageId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users ||
        isAdmin()
      );
    }

    // --- User Interactions ---
    match /interactions/{interactionId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.fromId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.fromId || isAdmin());
    }

    // --- Global Surveillance (Live Map) ---
    match /active_sessions/{sessionId} {
      // Only admins can see where souls are located
      allow read: if isAdmin();
      
      // Allow authenticated pings for tracking (prevents anonymous spam)
      allow create, update: if isSignedIn() && (request.auth.uid == request.resource.data.uid || isAdmin());
      
      // Only admins can purge session data
      allow delete: if isAdmin();
    }
  }
}
